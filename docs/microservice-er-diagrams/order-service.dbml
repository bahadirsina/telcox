// =============================================================================
// order-service / order_db
// Spring microservice database boundary: order-service
//
// FK politikasi:
//   * Servis ICI iliskiler fiziksel FK ile kurulur.
//   * customerId, productId, changedByUserId, msisdn, iccid gibi servis DISI
//     referanslar yalnizca UUID/business key olarak tutulur, FK YOKTUR.
// =============================================================================

Table ORDER_SERVICE_ORDER {
  id uuid [primary key]
  orderNumber varchar [unique]
  customerId uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  orderType varchar [note: 'NEW | UPGRADE | PORT_IN | ADDON | DEVICE_SALE']
  status varchar [note: 'CREATED | CONFIRMED | IN_FULFILLMENT | COMPLETED | CANCELLED']
  totalAmount numeric
  currency varchar
  channel varchar [note: 'WEB | STORE | CALL_CENTER | DEALER']
  createdAt timestamp
  updatedAt timestamp
}

Table ORDER_SERVICE_ORDER_ITEM {
  id uuid [primary key]
  orderId uuid [not null]
  productId uuid [not null, note: 'logical ref -> product-service.PRODUCT.id']
  quantity int
  unitPrice numeric
  totalPrice numeric
  metadataJson jsonb
}

Table ORDER_SERVICE_STATUS_HISTORY {
  id uuid [primary key]
  orderId uuid [not null]
  oldStatus varchar
  newStatus varchar
  changedAt timestamp
  changedByUserId uuid [note: 'logical ref -> identity-service.USER.id']
}

Table ORDER_SERVICE_FULFILLMENT {
  id uuid [primary key]
  orderId uuid [not null]
  fulfillmentType varchar [note: 'SIM_PROVISION | NUMBER_PORT | DEVICE_SHIPMENT']
  status varchar [note: 'PENDING | IN_PROGRESS | COMPLETED | FAILED']
  msisdn varchar [note: 'logical ref -> inventory-service.MSISDN.msisdn']
  iccid varchar [note: 'logical ref -> inventory-service.SIM_CARD.iccid']
  scheduledAt timestamp
  completedAt timestamp
  errorMessage varchar
}

Table ORDER_SERVICE_SAGA_STATE {
  id uuid [primary key]
  orderId uuid [unique, not null]
  currentStep varchar
  stepStatus varchar [note: 'STARTED | COMPLETED | COMPENSATED | FAILED']
  payloadJson jsonb
  lastUpdatedAt timestamp
}

Table ORDER_SERVICE_OUTBOX_EVENT {
  id uuid [primary key]
  aggregateId uuid [note: 'soft ref - heterojen aggregate tipleri, FK YOK']
  aggregateType varchar
  eventType varchar
  payloadJson jsonb
  status varchar [note: 'PENDING | PUBLISHED | FAILED']
  createdAt timestamp
  publishedAt timestamp
}

Table ORDER_SERVICE_PROCESSED_EVENT {
  id uuid [primary key]
  eventId uuid [unique]
  eventType varchar
  sourceService varchar
  aggregateId uuid
  processedAt timestamp
  status varchar [note: 'PROCESSED | FAILED']
  errorMessage varchar
  createdAt timestamp
}

// --- Servis ici fiziksel FK iliskileri ---
Ref order_items:           ORDER_SERVICE_ORDER_ITEM.orderId      > ORDER_SERVICE_ORDER.id  // N-1, physical FK
Ref order_status_history:  ORDER_SERVICE_STATUS_HISTORY.orderId  > ORDER_SERVICE_ORDER.id  // N-1, physical FK
Ref order_fulfillments:    ORDER_SERVICE_FULFILLMENT.orderId     > ORDER_SERVICE_ORDER.id  // N-1, physical FK
Ref order_saga_state:      ORDER_SERVICE_SAGA_STATE.orderId      - ORDER_SERVICE_ORDER.id  // 1-1, physical FK
