// =============================================================================
// inventory-service / inventory_db
// Spring microservice database boundary: inventory-service
// (MSISDN havuzu, SIM kart, cihaz, stok lokasyonu ve envanteri)
//
// FK politikasi:
//   * STOCK_ITEM -> STOCK_LOCATION fiziksel FK ile baglanir.
//   * STOCK_ITEM.itemRefId heterojen (SIM_CARD.id veya DEVICE.id) oldugundan
//     fiziksel FK uygulanmaz (polymorphic ref).
//   * SIM_CARD.assignedSubscriptionId, MSISDN.assignedSubscriptionId,
//     DEVICE.assignedCustomerId yalnizca UUID olarak tutulur, FK YOKTUR.
// =============================================================================

Table INVENTORY_SERVICE_SIM_CARD {
  id uuid [primary key]
  iccid varchar [unique, not null]
  imsi varchar [unique, not null]
  simType varchar [note: 'PHYSICAL | ESIM']
  status varchar [note: 'AVAILABLE | RESERVED | ACTIVE | DEACTIVATED']
  assignedSubscriptionId uuid [note: 'logical ref -> subscription-service.SUBSCRIPTION.id']
  createdAt timestamp
  updatedAt timestamp
}

Table INVENTORY_SERVICE_MSISDN {
  id uuid [primary key]
  msisdn varchar [unique, not null]
  msisdnType varchar [note: 'REGULAR | GOLD | PLATINUM']
  status varchar [note: 'AVAILABLE | RESERVED | ACTIVE | QUARANTINED']
  assignedSubscriptionId uuid [note: 'logical ref -> subscription-service.SUBSCRIPTION.id']
  reservedUntil timestamp
  createdAt timestamp
}

Table INVENTORY_SERVICE_DEVICE {
  id uuid [primary key]
  imei varchar [unique, not null]
  brand varchar
  model varchar
  status varchar [note: 'IN_STOCK | SOLD | RETURNED | DEFECTIVE']
  assignedCustomerId uuid [note: 'logical ref -> customer-service.CUSTOMER.id']
  createdAt timestamp
}

Table INVENTORY_SERVICE_STOCK_LOCATION {
  id uuid [primary key]
  code varchar [unique, not null]
  name varchar
  locationType varchar [note: 'WAREHOUSE | STORE | DEALER']
  address varchar
}

Table INVENTORY_SERVICE_STOCK_ITEM {
  id uuid [primary key]
  locationId uuid [not null]
  itemType varchar [note: 'SIM | DEVICE']
  itemRefId uuid [note: 'polymorphic - SIM_CARD.id veya DEVICE.id; FK YOK']
  quantity int
  updatedAt timestamp
}

Table INVENTORY_SERVICE_OUTBOX_EVENT {
  id uuid [primary key]
  aggregateId uuid [note: 'soft ref - heterojen aggregate tipleri, FK YOK']
  aggregateType varchar
  eventType varchar
  payloadJson jsonb
  status varchar [note: 'PENDING | PUBLISHED | FAILED']
  createdAt timestamp
  publishedAt timestamp
}

Table INVENTORY_SERVICE_PROCESSED_EVENT {
  id uuid [primary key]
  eventId uuid [unique]
  eventType varchar
  sourceService varchar
  aggregateId uuid
  processedAt timestamp
  status varchar [note: 'PROCESSED | FAILED']
  errorMessage varchar
  createdAt timestamp
}

// --- Servis ici fiziksel FK iliskileri ---
Ref inventory_stock_items_location: INVENTORY_SERVICE_STOCK_ITEM.locationId > INVENTORY_SERVICE_STOCK_LOCATION.id  // N-1, physical FK
