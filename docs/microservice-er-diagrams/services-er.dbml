// notification-service / notification_db
// =============================================================================
Table "public"."NOTIFICATION_SERVICE_TEMPLATE" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique]
  "channel" varchar(500) [note: 'EMAIL | SMS | PUSH']
  "language" varchar(500)
  "subject" varchar(500)
  "bodyTemplate" text
  "status" varchar(500) [note: 'DRAFT | ACTIVE | RETIRED']
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."NOTIFICATION_SERVICE_NOTIFICATION" {
  "id" uuid [pk, not null]
  "recipientType" varchar(500) [note: 'CUSTOMER | USER']
  "recipientId" uuid [note: 'logical ref -> customer-service.CUSTOMER.id veya identity-service.USER.id']
  "recipientAddress" varchar(500) [note: 'email/phone resolved at send-time']
  "channel" varchar(500)
  "templateCode" varchar(500) [note: 'logical ref -> NOTIFICATION_TEMPLATE.code (esnek baglanti)']
  "subject" varchar(500)
  "body" text
  "status" varchar(500) [note: 'PENDING | SENT | DELIVERED | FAILED']
  "providerMessageId" varchar(500)
  "sentAt" timestamp
  "deliveredAt" timestamp
  "errorMessage" varchar(500)
  "createdAt" timestamp
}

Table "public"."NOTIFICATION_SERVICE_PREFERENCE" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  "channel" varchar(500)
  "isOptedIn" boolean
  "updatedAt" timestamp
}

Table "public"."NOTIFICATION_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
