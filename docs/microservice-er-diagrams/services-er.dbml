// =============================================================================
// Telco CRM - Consolidated Microservice ER Diagram
// =============================================================================
// FK POLITIKASI:
//   * Servis ICI (ayni veritabani icindeki tablolar arasi): FIZIKSEL FK kullanilir.
//     `ref: > tablo.id` notasyonu fiziksel FOREIGN KEY constraint anlamina gelir.
//   * Servis ARASI (farkli mikroservis veritabanlari): FIZIKSEL FK YOKTUR.
//     Sadece UUID/business key tutulur, kolon notunda `logical ref -> ...` yazilir.
//     Tutarliik event-driven (Outbox/Inbox pattern) ile saglanir.
//
//   * `*_OUTBOX_EVENT.aggregateId` jenerik bir alandir, birden fazla aggregate
//     tipini tutabildigi icin FIZIKSEL FK kurulmaz (yumusak referans).
//   * `*_PROCESSED_EVENT.eventId` baska bir servisten gelen event'in id'sidir,
//     dolayisiyla bu DB'de FK referansi olamaz.
// =============================================================================


// =============================================================================
// identity-service / identity_db
// =============================================================================
Table "public"."IDENTITY_SERVICE_USER" {
  "id" uuid [pk, not null]
  "email" varchar(500) [unique, not null]
  "passwordHash" varchar(500) [not null]
  "status" varchar(500) [note: 'ACTIVE | LOCKED | DISABLED']
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."IDENTITY_SERVICE_ROLE" {
  "id" uuid [pk, not null]
  "name" varchar(500) [unique, not null]
  "description" varchar(500)
}

Table "public"."IDENTITY_SERVICE_PERMISSION" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique, not null]
  "description" varchar(500)
}

Table "public"."IDENTITY_SERVICE_USER_ROLE" {
  "userId" uuid [not null, ref: > "public"."IDENTITY_SERVICE_USER"."id"]
  "roleId" uuid [not null, ref: > "public"."IDENTITY_SERVICE_ROLE"."id"]

  Indexes {
    (userId, roleId) [pk]
  }
}

Table "public"."IDENTITY_SERVICE_ROLE_PERMISSION" {
  "roleId" uuid [not null, ref: > "public"."IDENTITY_SERVICE_ROLE"."id"]
  "permissionId" uuid [not null, ref: > "public"."IDENTITY_SERVICE_PERMISSION"."id"]

  Indexes {
    (roleId, permissionId) [pk]
  }
}

Table "public"."IDENTITY_SERVICE_REFRESH_TOKEN" {
  "id" uuid [pk, not null]
  "userId" uuid [not null, ref: > "public"."IDENTITY_SERVICE_USER"."id"]
  "tokenHash" varchar(500) [not null]
  "expiresAt" timestamp
  "revokedAt" timestamp
  "createdAt" timestamp
}

Table "public"."IDENTITY_SERVICE_AUDIT_LOG" {
  "id" uuid [pk, not null]
  "actorUserId" uuid [ref: > "public"."IDENTITY_SERVICE_USER"."id"]
  "action" varchar(500)
  "entityType" varchar(500)
  "entityId" uuid
  "oldValueJson" jsonb
  "newValueJson" jsonb
  "correlationId" varchar(500)
  "createdAt" timestamp
}

Table "public"."IDENTITY_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500) [note: 'PENDING | PUBLISHED | FAILED']
  "createdAt" timestamp
  "publishedAt" timestamp
}

Table "public"."IDENTITY_SERVICE_PROCESSED_EVENT" {
  "id" uuid [pk, not null]
  "eventId" uuid [unique, not null]
  "eventType" varchar(500)
  "sourceService" varchar(500)
  "aggregateId" uuid
  "processedAt" timestamp
  "status" varchar(500) [note: 'PROCESSED | FAILED']
  "errorMessage" varchar(500)
  "createdAt" timestamp
}


// =============================================================================
// customer-service / customer_db
// =============================================================================
Table "public"."CUSTOMER_SERVICE_CUSTOMER" {
  "id" uuid [pk, not null]
  "identityUserId" uuid [unique, note: 'logical ref -> identity-service.USER.id']
  "customerNumber" varchar(500) [unique]
  "customerType" varchar(500) [note: 'INDIVIDUAL | CORPORATE']
  "firstName" varchar(500)
  "lastName" varchar(500)
  "companyName" varchar(500)
  "taxNumber" varchar(500)
  "nationalId" varchar(500) [note: 'Encrypted TCKN/VKN']
  "dateOfBirth" date
  "segment" varchar(500) [note: 'MASS | SME | CORPORATE | VIP']
  "status" varchar(500) [note: 'PROSPECT | ACTIVE | SUSPENDED | CLOSED']
  "createdAt" timestamp
  "updatedAt" timestamp
  "deletedAt" timestamp [note: 'Soft delete (KVKK/GDPR)']
}

Table "public"."CUSTOMER_SERVICE_ADDRESS" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, ref: > "public"."CUSTOMER_SERVICE_CUSTOMER"."id"]
  "addressType" varchar(500) [note: 'BILLING | SHIPPING | CONTACT']
  "country" varchar(500)
  "city" varchar(500)
  "district" varchar(500)
  "street" varchar(500)
  "buildingNo" varchar(500)
  "postalCode" varchar(500)
  "isDefault" boolean
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_CONTACT" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, ref: > "public"."CUSTOMER_SERVICE_CUSTOMER"."id"]
  "contactType" varchar(500) [note: 'EMAIL | PHONE | MOBILE']
  "contactValue" varchar(500)
  "isVerified" boolean
  "isPrimary" boolean
  "verifiedAt" timestamp
  "createdAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_DOCUMENT" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, ref: > "public"."CUSTOMER_SERVICE_CUSTOMER"."id"]
  "documentType" varchar(500) [note: 'ID_CARD | PASSPORT | CONTRACT | TAX_CERT']
  "documentNumber" varchar(500)
  "fileUrl" varchar(500)
  "verificationStatus" varchar(500) [note: 'PENDING | VERIFIED | REJECTED']
  "uploadedByUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "uploadedAt" timestamp
  "verifiedAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_NOTE" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, ref: > "public"."CUSTOMER_SERVICE_CUSTOMER"."id"]
  "authorUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "noteText" text
  "createdAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_CONSENT" {
  "id" uuid [pk, not null]
  "customerId" uuid [not null, ref: > "public"."CUSTOMER_SERVICE_CUSTOMER"."id"]
  "consentType" varchar(500) [note: 'KVKK | MARKETING | DATA_SHARING']
  "channel" varchar(500) [note: 'EMAIL | SMS | CALL']
  "isGranted" boolean
  "grantedAt" timestamp
  "revokedAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_AUDIT_LOG" {
  "id" uuid [pk, not null]
  "actorUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "action" varchar(500)
  "entityType" varchar(500)
  "entityId" uuid
  "oldValueJson" jsonb
  "newValueJson" jsonb
  "correlationId" varchar(500)
  "createdAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500) [note: 'PENDING | PUBLISHED | FAILED']
  "createdAt" timestamp
  "publishedAt" timestamp
}

Table "public"."CUSTOMER_SERVICE_PROCESSED_EVENT" {
  "id" uuid [pk, not null]
  "eventId" uuid [unique]
  "eventType" varchar(500)
  "sourceService" varchar(500)
  "aggregateId" uuid
  "processedAt" timestamp
  "status" varchar(500) [note: 'PROCESSED | FAILED']
  "errorMessage" varchar(500)
  "createdAt" timestamp
}


// =============================================================================
// product-catalog-service / product_db
// =============================================================================
Table "public"."PRODUCT_SERVICE_PRODUCT" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique]
  "name" varchar(500)
  "description" text
  "productType" varchar(500) [note: 'PLAN | ADDON | DEVICE | SERVICE']
  "status" varchar(500) [note: 'DRAFT | ACTIVE | RETIRED']
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."PRODUCT_SERVICE_PLAN" {
  "id" uuid [pk, not null]
  "productId" uuid [unique, not null, note: 'one-to-one alt-tip extension of PRODUCT', ref: > "public"."PRODUCT_SERVICE_PRODUCT"."id"]
  "planType" varchar(500) [note: 'PREPAID | POSTPAID | HYBRID']
  "commitmentMonths" int
  "monthlyPrice" numeric
  "currency" varchar(500)
  "validFrom" date
  "validTo" date
}

Table "public"."PRODUCT_SERVICE_PLAN_FEATURE" {
  "id" uuid [pk, not null]
  "planId" uuid [not null, ref: > "public"."PRODUCT_SERVICE_PLAN"."id"]
  "featureType" varchar(500) [note: 'VOICE_MIN | SMS_COUNT | DATA_MB | INTL_MIN']
  "allowance" numeric
  "unit" varchar(500)
  "isUnlimited" boolean
}

Table "public"."PRODUCT_SERVICE_PRICE" {
  "id" uuid [pk, not null]
  "productId" uuid [not null, ref: > "public"."PRODUCT_SERVICE_PRODUCT"."id"]
  "price" numeric
  "currency" varchar(500)
  "taxIncluded" boolean
  "validFrom" date
  "validTo" date
}

Table "public"."PRODUCT_SERVICE_CATEGORY" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique]
  "name" varchar(500)
  "parentCategoryId" uuid [ref: > "public"."PRODUCT_SERVICE_CATEGORY"."id"]
}

Table "public"."PRODUCT_SERVICE_PRODUCT_CATEGORY" {
  "productId" uuid [not null, ref: > "public"."PRODUCT_SERVICE_PRODUCT"."id"]
  "categoryId" uuid [not null, ref: > "public"."PRODUCT_SERVICE_CATEGORY"."id"]

  Indexes {
    (productId, categoryId) [pk]
  }
}

Table "public"."PRODUCT_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500)
  "createdAt" timestamp
  "publishedAt" timestamp
}

Table "public"."PRODUCT_SERVICE_PROCESSED_EVENT" {
  "id" uuid [pk, not null]
  "eventId" uuid [unique]
  "eventType" varchar(500)
  "sourceService" varchar(500)
