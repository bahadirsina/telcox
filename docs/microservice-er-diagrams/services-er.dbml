Table "public"."SUBSCRIPTION_SERVICE_SUBSCRIPTION" {
  "id" uuid [pk, not null]
  "subscriptionNumber" varchar(500) [unique]
  "customerId" uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  "planId" uuid [not null, note: 'logical ref -> product-service.PLAN.id']
  "msisdn" varchar(500) [note: 'logical ref -> inventory-service.MSISDN.msisdn']
  "iccid" varchar(500) [note: 'logical ref -> inventory-service.SIM_CARD.iccid']
  "status" varchar(500) [note: 'PENDING | ACTIVE | SUSPENDED | CANCELLED | TERMINATED']
  "billingDay" int
  "activatedAt" timestamp
  "deactivatedAt" timestamp
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."SUBSCRIPTION_SERVICE_PLAN_HISTORY" {
  "id" uuid [pk, not null]
