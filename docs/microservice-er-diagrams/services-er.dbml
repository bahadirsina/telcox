  "processedAt" timestamp
  "status" varchar(500)
  "errorMessage" varchar(500)
  "createdAt" timestamp
}


// =============================================================================
// ticket-service / ticket_db
// =============================================================================
Table "public"."TICKET_SERVICE_TICKET" {
  "id" uuid [pk, not null]
  "ticketNumber" varchar(500) [unique]
  "customerId" uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  "subject" varchar(500)
  "description" text
  "ticketType" varchar(500) [note: 'BILLING | TECHNICAL | SALES | COMPLAINT']
  "priority" varchar(500) [note: 'LOW | MEDIUM | HIGH | CRITICAL']
  "status" varchar(500) [note: 'OPEN | IN_PROGRESS | WAITING_CUSTOMER | RESOLVED | CLOSED']
  "slaDueAt" timestamp
  "assignedToUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "createdByUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "createdAt" timestamp
  "resolvedAt" timestamp
  "closedAt" timestamp
}

Table "public"."TICKET_SERVICE_COMMENT" {
  "id" uuid [pk, not null]
  "ticketId" uuid [not null, ref: > "public"."TICKET_SERVICE_TICKET"."id"]
  "authorUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "commentText" text
  "isInternal" boolean
  "createdAt" timestamp
}

Table "public"."TICKET_SERVICE_ATTACHMENT" {
  "id" uuid [pk, not null]
  "ticketId" uuid [not null, ref: > "public"."TICKET_SERVICE_TICKET"."id"]
  "fileName" varchar(500)
  "fileUrl" varchar(500)
  "fileSize" bigint
  "uploadedByUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "uploadedAt" timestamp
}

Table "public"."TICKET_SERVICE_STATUS_HISTORY" {
  "id" uuid [pk, not null]
  "ticketId" uuid [not null, ref: > "public"."TICKET_SERVICE_TICKET"."id"]
  "oldStatus" varchar(500)
  "newStatus" varchar(500)
  "changedAt" timestamp
  "changedByUserId" uuid [note: 'logical ref -> identity-service.USER.id']
  "comment" varchar(500)
}

Table "public"."TICKET_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500)
  "createdAt" timestamp
  "publishedAt" timestamp
}

Table "public"."TICKET_SERVICE_PROCESSED_EVENT" {
  "id" uuid [pk, not null]
  "eventId" uuid [unique]
  "eventType" varchar(500)
  "sourceService" varchar(500)
  "aggregateId" uuid
  "processedAt" timestamp
  "status" varchar(500)
  "errorMessage" varchar(500)
  "createdAt" timestamp
}


// =============================================================================
// campaign-service / campaign_db  (MVP sonrasi, scope-out kapsami)
// =============================================================================
Table "public"."CAMPAIGN_SERVICE_CAMPAIGN" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique]
  "name" varchar(500)
  "description" text
  "campaignType" varchar(500) [note: 'PROMOTION | DISCOUNT | LOYALTY | RETENTION']
  "targetSegment" varchar(500)
  "startDate" timestamp
  "endDate" timestamp
  "status" varchar(500) [note: 'DRAFT | ACTIVE | PAUSED | COMPLETED']
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."CAMPAIGN_SERVICE_RULE" {
  "id" uuid [pk, not null]
  "campaignId" uuid [not null, ref: > "public"."CAMPAIGN_SERVICE_CAMPAIGN"."id"]
  "ruleType" varchar(500) [note: 'MIN_USAGE | MIN_TENURE | SEGMENT_MATCH']
