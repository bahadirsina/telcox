}

Table "public"."CAMPAIGN_SERVICE_OFFER" {
  "id" uuid [pk, not null]
  "campaignId" uuid [not null, ref: > "public"."CAMPAIGN_SERVICE_CAMPAIGN"."id"]
  "productId" uuid [note: 'logical ref -> product-service.PRODUCT.id']
  "discountType" varchar(500) [note: 'PERCENT | AMOUNT | FREE_ADDON']
  "discountValue" numeric
  "durationMonths" int
}

Table "public"."CAMPAIGN_SERVICE_ELIGIBILITY" {
  "id" uuid [pk, not null]
  "campaignId" uuid [not null, ref: > "public"."CAMPAIGN_SERVICE_CAMPAIGN"."id"]
  "customerId" uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  "status" varchar(500) [note: 'ELIGIBLE | REDEEMED | EXPIRED']
  "eligibleAt" timestamp
  "redeemedAt" timestamp
}

Table "public"."CAMPAIGN_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500)
  "createdAt" timestamp
  "publishedAt" timestamp
}

Table "public"."CAMPAIGN_SERVICE_PROCESSED_EVENT" {
  "id" uuid [pk, not null]
  "eventId" uuid [unique]
  "eventType" varchar(500)
  "sourceService" varchar(500)
  "aggregateId" uuid
  "processedAt" timestamp
  "status" varchar(500)
  "errorMessage" varchar(500)
