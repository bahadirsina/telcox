  "payloadJson" jsonb
  "lastUpdatedAt" timestamp
}

Table "public"."ORDER_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
  "aggregateId" uuid [note: 'soft ref - heterojen aggregate tipleri']
  "aggregateType" varchar(500)
  "eventType" varchar(500)
  "payloadJson" jsonb
  "status" varchar(500)
