  "quotaType" varchar(500) [note: 'VOICE_MIN | SMS_COUNT | DATA_MB']
  "totalAllowance" numeric
  "usedAmount" numeric
  "remainingAmount" numeric
  "periodStart" timestamp
  "periodEnd" timestamp
}

Table "public"."USAGE_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
