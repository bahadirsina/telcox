Table "public"."INVENTORY_SERVICE_SIM_CARD" {
  "id" uuid [pk, not null]
  "iccid" varchar(500) [unique]
  "imsi" varchar(500) [unique]
  "simType" varchar(500) [note: 'PHYSICAL | ESIM']
  "status" varchar(500) [note: 'AVAILABLE | RESERVED | ACTIVE | DEACTIVATED']
  "assignedSubscriptionId" uuid [note: 'logical ref -> subscription-service.SUBSCRIPTION.id']
  "createdAt" timestamp
  "updatedAt" timestamp
}

Table "public"."INVENTORY_SERVICE_MSISDN" {
  "id" uuid [pk, not null]
  "msisdn" varchar(500) [unique]
  "msisdnType" varchar(500) [note: 'REGULAR | GOLD | PLATINUM']
  "status" varchar(500) [note: 'AVAILABLE | RESERVED | ACTIVE | QUARANTINED']
  "assignedSubscriptionId" uuid [note: 'logical ref -> subscription-service.SUBSCRIPTION.id']
  "reservedUntil" timestamp
  "createdAt" timestamp
}

Table "public"."INVENTORY_SERVICE_DEVICE" {
  "id" uuid [pk, not null]
  "imei" varchar(500) [unique]
  "brand" varchar(500)
  "model" varchar(500)
  "status" varchar(500) [note: 'IN_STOCK | SOLD | RETURNED | DEFECTIVE']
  "assignedCustomerId" uuid [note: 'logical ref -> customer-service.CUSTOMER.id']
  "createdAt" timestamp
}

Table "public"."INVENTORY_SERVICE_STOCK_LOCATION" {
  "id" uuid [pk, not null]
  "code" varchar(500) [unique]
  "name" varchar(500)
  "locationType" varchar(500) [note: 'WAREHOUSE | STORE | DEALER']
  "address" varchar(500)
}

Table "public"."INVENTORY_SERVICE_STOCK_ITEM" {
  "id" uuid [pk, not null]
  "locationId" uuid [not null, ref: > "public"."INVENTORY_SERVICE_STOCK_LOCATION"."id"]
  "itemType" varchar(500) [note: 'SIM | DEVICE']
  "itemRefId" uuid [note: 'soft ref - SIM_CARD.id veya DEVICE.id (heterojen)']
  "quantity" int
  "updatedAt" timestamp
}

Table "public"."INVENTORY_SERVICE_OUTBOX_EVENT" {
  "id" uuid [pk, not null]
