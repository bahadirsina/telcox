// =============================================================================
// subscription-service / subscription_db
// Spring microservice database boundary: subscription-service
//
// FK politikasi:
//   * Servis ICI iliskiler fiziksel FK ile kurulur.
//   * customerId, planId, msisdn, iccid, changedByUserId gibi servis DISI
//     referanslar yalnizca UUID/business key olarak tutulur, FK YOKTUR.
// =============================================================================

Table SUBSCRIPTION_SERVICE_SUBSCRIPTION {
  id uuid [primary key]
  subscriptionNumber varchar [unique]
  customerId uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  planId uuid [not null, note: 'logical ref -> product-service.PLAN.id']
  msisdn varchar [note: 'logical ref -> inventory-service.MSISDN.msisdn']
  iccid varchar [note: 'logical ref -> inventory-service.SIM_CARD.iccid']
  status varchar [note: 'PENDING | ACTIVE | SUSPENDED | CANCELLED | TERMINATED']
  billingDay int
  activatedAt timestamp
  deactivatedAt timestamp
  createdAt timestamp
  updatedAt timestamp
}

Table SUBSCRIPTION_SERVICE_PLAN_HISTORY {
  id uuid [primary key]
  subscriptionId uuid [not null]
  planId uuid [not null, note: 'logical ref -> product-service.PLAN.id']
  startDate timestamp
  endDate timestamp
  reason varchar
}

Table SUBSCRIPTION_SERVICE_ADDON {
  id uuid [primary key]
  subscriptionId uuid [not null]
  productId uuid [not null, note: 'logical ref -> product-service.PRODUCT.id']
  status varchar [note: 'ACTIVE | EXPIRED | CANCELLED']
  activatedAt timestamp
  expiresAt timestamp
}

Table SUBSCRIPTION_SERVICE_STATUS_HISTORY {
  id uuid [primary key]
  subscriptionId uuid [not null]
  oldStatus varchar
  newStatus varchar
  reason varchar
  changedAt timestamp
  changedByUserId uuid [note: 'logical ref -> identity-service.USER.id']
}

Table SUBSCRIPTION_SERVICE_AUDIT_LOG {
  id uuid [primary key]
  actorUserId uuid [note: 'logical ref -> identity-service.USER.id']
  action varchar
  entityType varchar
  entityId uuid
  oldValueJson jsonb
  newValueJson jsonb
  correlationId varchar
  createdAt timestamp
}

Table SUBSCRIPTION_SERVICE_OUTBOX_EVENT {
  id uuid [primary key]
  aggregateId uuid [note: 'soft ref - heterojen aggregate tipleri, FK YOK']
  aggregateType varchar
  eventType varchar
  payloadJson jsonb
  status varchar [note: 'PENDING | PUBLISHED | FAILED']
  createdAt timestamp
  publishedAt timestamp
}

Table SUBSCRIPTION_SERVICE_PROCESSED_EVENT {
  id uuid [primary key]
  eventId uuid [unique]
  eventType varchar
  sourceService varchar
  aggregateId uuid
  processedAt timestamp
  status varchar [note: 'PROCESSED | FAILED']
  errorMessage varchar
  createdAt timestamp
}

// --- Servis ici fiziksel FK iliskileri ---
Ref subscription_plan_history:   SUBSCRIPTION_SERVICE_PLAN_HISTORY.subscriptionId   > SUBSCRIPTION_SERVICE_SUBSCRIPTION.id  // N-1, physical FK
Ref subscription_addons:         SUBSCRIPTION_SERVICE_ADDON.subscriptionId          > SUBSCRIPTION_SERVICE_SUBSCRIPTION.id  // N-1, physical FK
Ref subscription_status_history: SUBSCRIPTION_SERVICE_STATUS_HISTORY.subscriptionId > SUBSCRIPTION_SERVICE_SUBSCRIPTION.id  // N-1, physical FK
