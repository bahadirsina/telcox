// =============================================================================
// campaign-service / campaign_db   (MVP sonrasi - scope-out)
// Spring microservice database boundary: campaign-service
//
// NOT: Doküman 6.2'de "Kampanya / promosyon motoru" Scope Out olarak
// belirtilmistir. Bu dosya hazirlik amaclidir; MVP fazinda servis
// implement edilmeyecektir.
//
// FK politikasi:
//   * Servis ICI iliskiler fiziksel FK ile kurulur.
//   * customerId, productId yalnizca UUID olarak tutulur, FK YOKTUR.
// =============================================================================

Table CAMPAIGN_SERVICE_CAMPAIGN {
  id uuid [primary key]
  code varchar [unique, not null]
  name varchar
  description text
  campaignType varchar [note: 'PROMOTION | DISCOUNT | LOYALTY | RETENTION']
  targetSegment varchar
  startDate timestamp
  endDate timestamp
  status varchar [note: 'DRAFT | ACTIVE | PAUSED | COMPLETED']
  createdAt timestamp
  updatedAt timestamp
}

Table CAMPAIGN_SERVICE_RULE {
  id uuid [primary key]
  campaignId uuid [not null]
  ruleType varchar [note: 'MIN_USAGE | MIN_TENURE | SEGMENT_MATCH']
  ruleJson jsonb
}

Table CAMPAIGN_SERVICE_OFFER {
  id uuid [primary key]
  campaignId uuid [not null]
  productId uuid [note: 'logical ref -> product-service.PRODUCT.id']
  discountType varchar [note: 'PERCENT | AMOUNT | FREE_ADDON']
  discountValue numeric
  durationMonths int
}

Table CAMPAIGN_SERVICE_ELIGIBILITY {
  id uuid [primary key]
  campaignId uuid [not null]
  customerId uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  status varchar [note: 'ELIGIBLE | REDEEMED | EXPIRED']
  eligibleAt timestamp
  redeemedAt timestamp
}

Table CAMPAIGN_SERVICE_OUTBOX_EVENT {
  id uuid [primary key]
  aggregateId uuid [note: 'soft ref - heterojen aggregate tipleri, FK YOK']
  aggregateType varchar
  eventType varchar
  payloadJson jsonb
  status varchar [note: 'PENDING | PUBLISHED | FAILED']
  createdAt timestamp
  publishedAt timestamp
}

Table CAMPAIGN_SERVICE_PROCESSED_EVENT {
  id uuid [primary key]
  eventId uuid [unique]
  eventType varchar
  sourceService varchar
  aggregateId uuid
  processedAt timestamp
  status varchar [note: 'PROCESSED | FAILED']
  errorMessage varchar
  createdAt timestamp
}

// --- Servis ici fiziksel FK iliskileri ---
Ref campaign_rules:        CAMPAIGN_SERVICE_RULE.campaignId        > CAMPAIGN_SERVICE_CAMPAIGN.id  // N-1, physical FK
Ref campaign_offers:       CAMPAIGN_SERVICE_OFFER.campaignId       > CAMPAIGN_SERVICE_CAMPAIGN.id  // N-1, physical FK
Ref campaign_eligibility:  CAMPAIGN_SERVICE_ELIGIBILITY.campaignId > CAMPAIGN_SERVICE_CAMPAIGN.id  // N-1, physical FK
