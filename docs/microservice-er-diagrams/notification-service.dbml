// =============================================================================
// notification-service / notification_db
// Spring microservice database boundary: notification-service
//
// FK politikasi:
//   * Servis ICI fiziksel FK yoktur (NOTIFICATION ile TEMPLATE arasinda
//     templateCode uzerinden esnek bir baglanti vardir; sablonun silinmesi
//     gecmis bildirimleri etkilememelidir).
//   * Servis DISI customerId/recipientId yalnizca UUID olarak tutulur.
// =============================================================================

Table NOTIFICATION_SERVICE_TEMPLATE {
  id uuid [primary key]
  code varchar [unique, not null]
  channel varchar [note: 'EMAIL | SMS | PUSH']
  language varchar
  subject varchar
  bodyTemplate text
  status varchar [note: 'DRAFT | ACTIVE | RETIRED']
  createdAt timestamp
  updatedAt timestamp
}

Table NOTIFICATION_SERVICE_NOTIFICATION {
  id uuid [primary key]
  recipientType varchar [note: 'CUSTOMER | USER']
  recipientId uuid [note: 'logical ref -> customer-service.CUSTOMER.id veya identity-service.USER.id']
  recipientAddress varchar [note: 'email/phone resolved at send-time']
  channel varchar
  templateCode varchar [note: 'logical ref -> TEMPLATE.code (esnek baglanti, FK YOK)']
  subject varchar
  body text
  status varchar [note: 'PENDING | SENT | DELIVERED | FAILED']
  providerMessageId varchar
  sentAt timestamp
  deliveredAt timestamp
  errorMessage varchar
  createdAt timestamp
}

Table NOTIFICATION_SERVICE_PREFERENCE {
  id uuid [primary key]
  customerId uuid [not null, note: 'logical ref -> customer-service.CUSTOMER.id']
  channel varchar
  isOptedIn boolean
  updatedAt timestamp
}

Table NOTIFICATION_SERVICE_OUTBOX_EVENT {
  id uuid [primary key]
  aggregateId uuid [note: 'soft ref - heterojen aggregate tipleri, FK YOK']
  aggregateType varchar
  eventType varchar
  payloadJson jsonb
  status varchar [note: 'PENDING | PUBLISHED | FAILED']
  createdAt timestamp
  publishedAt timestamp
}

Table NOTIFICATION_SERVICE_PROCESSED_EVENT {
  id uuid [primary key]
  eventId uuid [unique]
  eventType varchar
  sourceService varchar
  aggregateId uuid
  processedAt timestamp
  status varchar [note: 'PROCESSED | FAILED']
  errorMessage varchar
  createdAt timestamp
}

// notification-service icinde fiziksel FK yoktur:
// NOTIFICATION.templateCode -> TEMPLATE.code arasindaki iliski yumusak
// referanstir; sablon silinse de gecmis bildirim kayitlari kalmalidir.
