# =============================================================================
# Telco CRM Platform - Ornek Ortam Degiskenleri (lokal mvn ile calistirirken)
#
# Compose icinde calistirirken bu degiskenler docker-compose.yml'de set edilir.
# Sadece IDE/terminal'den dogrudan mvn spring-boot:run yaparken kullanin.
# =============================================================================

# Veritabani kimlik bilgileri (tum servisler ayni user/password kullanir,
# her servis sadece kendi DB'sine erisir)
DB_USER=telcox
DB_PASSWORD=telcox

# PostgreSQL portlari (compose disinda calistirirken localhost uzerinden)
# identity            -> 5432
# customer            -> 5433
# product-catalog     -> 5434
# order               -> 5435
# subscription        -> 5436
# usage               -> 5437
# billing             -> 5438
# payment             -> 5439
# notification        -> 5440
# ticket              -> 5441

# Altyapi (compose ile baslatildiginda otomatik calisir)
KAFKA_BOOTSTRAP=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
EUREKA_URL=http://localhost:8761/eureka/
CONFIG_SERVER_URL=http://localhost:8888

# JWT (identity-service)
JWT_SECRET=please-change-in-production-min-32-bytes-secret-key
