# =============================================================================
# Telco CRM Platform - Ornek Ortam Degiskenleri (lokal mvn ile calistirirken)
#
# Compose icinde calistirirken bu degiskenler docker-compose.yml'de set edilir.
# Sadece IDE/terminal'den dogrudan mvn spring-boot:run yaparken kullanin.
#
# NOT: Tum host portlari 1xxxx araligina shift edildi (baska projelerle
# cakismamasi icin). Container icindeki portlar standart kalir.
# =============================================================================

# Veritabani kimlik bilgileri (tum servisler ayni user/password kullanir,
# her servis sadece kendi DB'sine erisir)
DB_USER=telcox
DB_PASSWORD=telcox

# PostgreSQL host portlari (lokal mvn ile calistirirken)
# identity            -> 15432
# customer            -> 15433
# product-catalog     -> 15434
# order               -> 15435
# subscription        -> 15436
# usage               -> 15437
# billing             -> 15438
# payment             -> 15439
# notification        -> 15440
# ticket              -> 15441

# Altyapi servisleri (lokal mvn icin host portlari)
KAFKA_BOOTSTRAP=localhost:19092
REDIS_HOST=localhost
REDIS_PORT=16379
EUREKA_URL=http://localhost:18761/eureka/
CONFIG_SERVER_URL=http://localhost:18888

# JWT (identity-service)
JWT_SECRET=please-change-in-production-min-32-bytes-secret-key

# SMTP (notification-service) - lokal MailHog
SMTP_HOST=localhost
SMTP_PORT=11025
